{
  "auto_detect_input_route": {
    "enabled": true,
    "on_plain_text_input": true,
    "detect": {
      "wallet_address": {
        "evm_regex": "^0x[a-fA-F0-9]{40}$",
        "route": "wallet_analysis",
        "auto_run": true,
        "report": "wallet"
      },
      "token_contract": {
        "evm_regex": "^0x[a-fA-F0-9]{40}$",
        "route": "contract_analysis",
        "auto_run": true,
        "report": "token",
        "after_report_prompt": "是否加入自选列表？"
      }
    },
    "disambiguation_rule": "如果无法从上下文区分地址类型，先尝试币种合约分析；若无代币信息则回退钱包地址分析"
  },
  "wallet_analysis": {
    "trigger": "act:invest.wallet.analyze.prompt",
    "prompt": "请输入需要分析的钱包地址（默认使用 query-address-info 分析并返回报告）",
    "default_skill": "query-address-info"
  },
  "contract_analysis": {
    "trigger": "act:invest.contract.analyze.prompt",
    "prompt": "请输入需要分析的币种合约地址（默认使用 query-token-audit + query-token-info + opentwitter-mcp）",
    "default_skills": [
      "query-token-audit",
      "query-token-info",
      "opentwitter-mcp"
    ],
    "display_name": "币种分析",
    "report_sections": [
      "1) 合约安全审计（query-token-audit）",
      "2) 代币基础与市场数据（query-token-info）",
      "3) 资金与热度补充（query-token-info扩展）",
      "4) 推特叙事雷达（opentwitter-mcp）"
    ],
    "twitter_narrative_radar": {
      "template": "smart-investment-assistant/twitter-narrative-radar-template.md",
      "required": true,
      "search_inputs": [
        "contractAddress",
        "symbol",
        "projectName"
      ]
    }
  },
  "surf_research": {
    "trigger": "act:invest.surf.research.prompt",
    "prompt": "请告诉我你要投研的项目名/推特账号/官网（例如：@UnitasLabs）",
    "workflow": "asksurf_frontend_login_session",
    "steps": [
      "复用已登录 asksurf 页面",
      "提交项目投研请求（完整研报）",
      "等待生成（默认最长5分钟）",
      "抓取并原样返回研报全文"
    ]
  }
}
