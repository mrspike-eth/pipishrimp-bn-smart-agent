{
  "trigger_on_enter": "nav:watchlist",
  "menu_logic": {
    "level2": {
      "show_only_token_buttons": true,
      "hide_other_options": true,
      "token_button_callback": "nav:watchlist.token.{symbol}"
    },
    "level3": {
      "title_format": "%s",
      "detail_line1_format": "市值：%s 流动性：%s 24h交易量：%s",
      "detail_line2_format": "持有者：%s wallet持仓情况：%s",
      "detail_line3_format": "合约地址：%s",
      "number_format": {
        "thousands_separator": ",",
        "decimals": 0,
        "integer_only": true
      },
      "buttons": [
        {"text": "wallet购买", "callback": "act:watchlist.wallet.buy.{address}", "executor": "wallet_trade", "action": "buy"},
        {"text": "wallet卖出", "callback": "act:watchlist.wallet.sell.{address}", "executor": "wallet_trade", "action": "sell"},
        {"text": "spot购买", "callback": "act:watchlist.spot.buy.{symbol}", "executor": "spot_trade", "action": "buy"},
        {"text": "spot卖出", "callback": "act:watchlist.spot.sell.{symbol}", "executor": "spot_trade", "action": "sell"},
        {"text": "添加币种", "callback": "act:watchlist.add"},
        {"text": "删除币种", "callback": "act:watchlist.remove"}
      ],
      "post_trade_sync": {
        "enabled": true,
        "wallet": true,
        "spot": true,
        "auto_refresh_watchlist": true
      }
    }
  },
  "data_source": {
    "add_flow": "invest_assistant.contract_analysis",
    "required_skills": ["query-token-info", "query-token-audit"],
    "runtime_watchlist_file": "/Users/chenshuang/.openclaw/workspace-coding/secure/watchlist_tokens.json"
  }
}
